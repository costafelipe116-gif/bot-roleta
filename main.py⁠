import os
import io
import telebot
from google import genai
from PIL import Image

# Carrega as chaves de ambiente do Railway
BOT_TOKEN = os.getenv("BOT_TOKEN")
GEMINI_API_KEY = os.getenv("GEMINI_API_KEY")

if not BOT_TOKEN or not GEMINI_API_KEY:
    raise ValueError("ERRO CRÍTICO: BOT_TOKEN ou GEMINI_API_KEY não configurados nas variáveis do Railway!")

# Inicializa o bot do Telegram e o client do Gemini
bot = telebot.TeleBot(BOT_TOKEN)
client = genai.Client(api_key=GEMINI_API_KEY)

@bot.message_handler(commands=['start', 'help'])
def enviar_boas_vindas(message):
    bot.reply_to(
        message, 
        "🤖 **Robô KP & Cavalos Ativado!**\n\n"
        "Mande o print do histórico da roleta para processar a análise dinâmica e gerar o sinal de entrada."
    )

@bot.message_handler(content_types=['photo'])
def analisar_print(message):
    bot.reply_to(message, "🔍 Lendo o print da roleta... Mapeando Racetrack, núcleos KP e calculando sinal!")
    
    try:
        # Pega a foto de maior resolução enviada
        file_info = bot.get_file(message.photo[-1].file_id)
        downloaded_file = bot.download_file(file_info.file_path)
        
        image_stream = io.BytesIO(downloaded_file)
        img = Image.open(image_stream)
        
        prompt = (
            "Você é um analista especialista em roleta e estratégias de cassino. "
            "Analise os números visíveis no histórico deste print e monte uma análise estritamente neste formato de 4 tópicos:\n\n"
            "1. Mapeamento Geral do Racetrack:\n"
            "- Tendência Geográfica (Esquerdo vs Direito com porcentagens reais baseadas no print).\n"
            "- Distribuição Topo vs Baixo.\n\n"
            "2. Raio-X da Jogada KP:\n"
            "- Status e frequência dos 3 núcleos (Núcleo 14 com 5 vizinhos, Núcleo 25 com 2 vizinhos, Núcleo 11 com 2 vizinhos) em porcentagem.\n"
            "- Situação da sequência (se está batendo seguido ou alternado).\n"
            "- Núcleo Dominante.\n\n"
            "3. Famílias de Cavalos (Terminais):\n"
            "- Porcentagens dos Cavalos 2/5/8, 1/4/7 e 0/3/6/9.\n"
            "- Família mais quente cruzada com a KP.\n\n"
            "4. Direcionamento e Sinal de Entrada:\n"
            "🚨 SINAL DE AGORA - ATENÇÃO! 🚨\n"
            "- Indicação exata de onde jogar com base no lado mais forte e probabilidade alta da mesa atual."
        )
        
        response = client.models.generate_content(
            model='gemini-2.5-flash',
            contents=[img, prompt]
        )
        
        bot.reply_to(message, response.text, parse_mode="Markdown")
        
    except Exception as e:
        bot.reply_to(message, f"❌ Erro ao processar a imagem: {e}")

if __name__ == "__main__":
    print("Iniciando limpeza de webhooks antigos...")
    try:
        bot.remove_webhook()
    except Exception:
        pass
        
    print("Bot rodando 24/7 com análise visual dinâmica...")
    bot.infinity_polling(timeout=60, long_polling_timeout=60)

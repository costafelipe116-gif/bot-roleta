[phases.setup]
nixPkgs = ["python3", "gcc"]

[phases.install]
cmds = [
    "python -m venv .venv",
    ".venv/bin/pip install --upgrade pip",
    ".venv/bin/pip install -r requirements.txt",
    ".venv/bin/playwright install chromium",
    ".venv/bin/playwright install-deps chromium"
]

[start]
cmd = ".venv/bin/python main.py"
